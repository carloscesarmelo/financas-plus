# Copie este arquivo para .env e defina um valor próprio e secreto.
# Gere um com: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=troque-por-um-valor-secreto

# Token que você define no painel da Kiwify e usa como query param na URL do
# webhook: https://SEU_DOMINIO/webhooks/kiwify?token=KIWIFY_WEBHOOK_TOKEN
KIWIFY_WEBHOOK_TOKEN=troque-por-um-token-secreto

# Mapeia o product_id de cada oferta criada na Kiwify para o plano interno.
# Preencha com os IDs reais depois de criar os produtos Mensal/Anual/Vitalício.
KIWIFY_PLAN_MAP={"PRODUCT_ID_MENSAL":"mensal","PRODUCT_ID_ANUAL":"anual","PRODUCT_ID_VITALICIO":"vitalicio"}
